# WalletConnect — get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# CoinGecko API (optional – free tier works without a key, but rate-limits apply)
COINGECKO_API_KEY=

# DexScreener (no key required)
# SEED token contract on Ethereum
NEXT_PUBLIC_SEED_ETH_ADDRESS=
# SEED token contract on Solana
NEXT_PUBLIC_SEED_SOL_ADDRESS=
# SUSD token contract on Ethereum
NEXT_PUBLIC_SUSD_ETH_ADDRESS=

# Resend — transactional email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@seedcoin.org
CONTACT_TO_ADDRESS=info@seedcoin.org

# Upstash Redis — rate limiting (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Neon Postgres — newsletter signups (https://neon.tech)
DATABASE_URL=

# Analytics — Plausible (self-hosted or cloud)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=seedcoin.org
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# Site URL
NEXT_PUBLIC_SITE_URL=https://seedcoin.org
